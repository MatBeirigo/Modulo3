{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "ControlApi.Services.BroadcastReceiverService": "Information",
      "ControlApi.Services.DataAggregationService": "Debug"
    }
  },
  "AllowedHosts": "*",
  "BroadcastSettings": {
    "TcpPort": 5001,
    "UdpPort": 5002,
    "BroadcastPort": 5010,
    "Module6Port": 5006,
    "StaleThresholdSeconds": 10,
    "PollingIntervalSeconds": 5,
    "HistoricalBufferSize": 1000,
    "ProcessorThreadCount": 4
  }
}